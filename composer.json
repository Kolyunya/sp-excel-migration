{
    "name": "sp/excel-migration",
    "type": "project",
    "autoload": {
        "psr-4": {
            "App\\": "sources/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Test\\": "tests/"
        }
    },
    "require": {
        "php": "^8.5",
        "elasticsearch/elasticsearch": "^9.4",
        "fakerphp/faker": "^1.24",
        "league/csv": "^9.28",
        "symfony/console": "^8.0",
        "symfony/http-client": "^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.1",
        "phpstan/phpstan": "^2.1",
        "friendsofphp/php-cs-fixer": "^3.95"
    },
    "scripts": {
        "qa": [
            "@analyze",
            "@test",
            "@validate-style"
        ],
        "analyze": "vendor/bin/phpstan analyze",
        "test": "vendor/bin/phpunit",
        "validate-style": "vendor/bin/php-cs-fixer fix --diff --dry-run --verbose"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
